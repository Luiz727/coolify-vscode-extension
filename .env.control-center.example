COOLIFY_BASE_URL=https://coolify.seudominio.com
COOLIFY_TOKEN=seu_token_aqui

# Opcional: habilita login web quando usuario e senha estiverem preenchidos.
WEB_AUTH_USER=
WEB_AUTH_PASSWORD=

# Opcional: token fixo de acesso para automacoes.
WEB_ACCESS_TOKEN=

# Opcional: caminho do arquivo JSONL de auditoria persistente.
AUDIT_LOG_PATH=/var/lib/control-center/audit.log.jsonl
