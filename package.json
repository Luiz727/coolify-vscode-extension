{
  "name": "vscode-coolify",
  "displayName": "Coolify Deployments",
  "description": "Track and deploy your Coolify applications right from Visual Studio Code",
  "version": "1.0.4",
  "author": {
    "name": "Nixcon Sistemas"
  },
  "publisher": "NixconSistemas",
  "icon": "public/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Luiz727/coolify-vscode-extension"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onChatParticipant:coolify.chat",
    "onLanguageModelTool:coolify-configure",
    "onLanguageModelTool:coolify-healthCheck",
    "onLanguageModelTool:coolify-listApplications",
    "onLanguageModelTool:coolify-getApplicationStatus",
    "onLanguageModelTool:coolify-startDeployment",
    "onLanguageModelTool:coolify-applicationLifecycle",
    "onLanguageModelTool:coolify-getDeploymentLogs",
    "onLanguageModelTool:coolify-listServices",
    "onLanguageModelTool:coolify-serviceLifecycle",
    "onLanguageModelTool:coolify-listDatabases",
    "onLanguageModelTool:coolify-databaseLifecycle",
    "onView:coolify-deployments",
    "onCommand:coolify.configure",
    "onCommand:coolify.reconfigure",
    "onCommand:coolify.createContext",
    "onCommand:coolify.switchContext",
    "onCommand:coolify.deleteContext",
    "onCommand:coolify.refreshApplications",
    "onCommand:coolify.sidebarLoadingIndicator",
    "onCommand:coolify.sidebarErrorIndicator",
    "onCommand:coolify.startDeployment",
    "onCommand:coolify.startApplication",
    "onCommand:coolify.stopApplication",
    "onCommand:coolify.restartApplication",
    "onCommand:coolify.selectLanguage",
    "onCommand:coolify.setEnvSyncConflictStrategy",
    "onCommand:coolify.showLogs",
    "onCommand:coolify.listEnvironmentVariables",
    "onCommand:coolify.createEnvironmentVariable",
    "onCommand:coolify.updateEnvironmentVariable",
    "onCommand:coolify.deleteEnvironmentVariable",
    "onCommand:coolify.syncEnvironmentVariablesFromFile",
    "onCommand:coolify.listDeployments",
    "onCommand:coolify.showDeploymentDetails",
    "onCommand:coolify.cancelDeployment",
    "onCommand:coolify.showDeploymentLogs",
    "onCommand:coolify.listServices",
    "onCommand:coolify.startService",
    "onCommand:coolify.stopService",
    "onCommand:coolify.restartService",
    "onCommand:coolify.listDatabases",
    "onCommand:coolify.startDatabase",
    "onCommand:coolify.stopDatabase",
    "onCommand:coolify.restartDatabase",
    "onCommand:coolify.listApplicationDeployments"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languageModelTools": [
      {
        "name": "coolify-configure",
        "toolReferenceName": "coolifyConfigure",
        "displayName": "Coolify Configurar",
        "modelDescription": "Inicia o fluxo de configuração do Coolify para definir URL do servidor e token da API com segurança.",
        "userDescription": "Configura URL e token da API do Coolify.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "configuration"
        ],
        "icon": "$(gear)",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "coolify-healthCheck",
        "toolReferenceName": "coolifyHealthCheck",
        "displayName": "Coolify Verificar Saúde",
        "modelDescription": "Verifica conectividade com o Coolify e validade do token da API.",
        "userDescription": "Valida conectividade e token do Coolify.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "health"
        ],
        "icon": "$(pulse)",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "coolify-listApplications",
        "toolReferenceName": "coolifyListApplications",
        "displayName": "Coolify Listar Aplicações",
        "modelDescription": "Lista aplicações disponíveis no Coolify com status e metadados.",
        "userDescription": "Lista aplicações do Coolify.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "applications"
        ],
        "icon": "$(list-unordered)",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "coolify-getApplicationStatus",
        "toolReferenceName": "coolifyGetApplicationStatus",
        "displayName": "Coolify Status da Aplicação",
        "modelDescription": "Obtém detalhes de status de uma aplicação do Coolify por id ou nome.",
        "userDescription": "Consulta status de uma aplicação do Coolify.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "status"
        ],
        "icon": "$(info)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "appId": {
              "type": "string",
              "description": "Application UUID in Coolify."
            },
            "appName": {
              "type": "string",
              "description": "Application name in Coolify."
            }
          },
          "anyOf": [
            {
              "required": [
                "appId"
              ]
            },
            {
              "required": [
                "appName"
              ]
            }
          ]
        }
      },
      {
        "name": "coolify-startDeployment",
        "toolReferenceName": "coolifyStartDeployment",
        "displayName": "Coolify Iniciar Deployment",
        "modelDescription": "Inicia um novo deployment para uma aplicação do Coolify por id ou nome.",
        "userDescription": "Inicia deploy de aplicação no Coolify.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "deploy"
        ],
        "icon": "$(rocket)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "appId": {
              "type": "string",
              "description": "Application UUID in Coolify."
            },
            "appName": {
              "type": "string",
              "description": "Application name in Coolify."
            }
          },
          "anyOf": [
            {
              "required": [
                "appId"
              ]
            },
            {
              "required": [
                "appName"
              ]
            }
          ]
        }
      },
      {
        "name": "coolify-applicationLifecycle",
        "toolReferenceName": "coolifyApplicationLifecycle",
        "displayName": "Coolify Ciclo de Vida da Aplicação",
        "modelDescription": "Executa ações de ciclo de vida (start, stop ou restart) para uma aplicação do Coolify.",
        "userDescription": "Executa start/stop/restart em aplicação do Coolify.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "lifecycle"
        ],
        "icon": "$(debug-restart)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": [
                "start",
                "stop",
                "restart"
              ],
              "description": "Lifecycle action to run."
            },
            "appId": {
              "type": "string",
              "description": "Application UUID in Coolify."
            },
            "appName": {
              "type": "string",
              "description": "Application name in Coolify."
            }
          },
          "required": [
            "action"
          ]
        }
      },
      {
        "name": "coolify-getDeploymentLogs",
        "toolReferenceName": "coolifyGetDeploymentLogs",
        "displayName": "Coolify Logs de Deployment",
        "modelDescription": "Retorna logs de um deployment por identificador do deployment ou por aplicação.",
        "userDescription": "Obtém logs de deployment no Coolify.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "logs"
        ],
        "icon": "$(output)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "deploymentId": {
              "type": "string",
              "description": "Deployment identifier in Coolify."
            },
            "appId": {
              "type": "string",
              "description": "Application UUID in Coolify."
            },
            "appName": {
              "type": "string",
              "description": "Application name in Coolify."
            }
          },
          "anyOf": [
            {
              "required": [
                "deploymentId"
              ]
            },
            {
              "required": [
                "appId"
              ]
            },
            {
              "required": [
                "appName"
              ]
            }
          ]
        }
      },
      {
        "name": "coolify-listServices",
        "toolReferenceName": "coolifyListServices",
        "displayName": "Coolify Listar Serviços",
        "modelDescription": "Lista serviços disponíveis no Coolify com status e metadados.",
        "userDescription": "Lista serviços do Coolify.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "services"
        ],
        "icon": "$(server)",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "coolify-serviceLifecycle",
        "toolReferenceName": "coolifyServiceLifecycle",
        "displayName": "Coolify Ciclo de Vida do Serviço",
        "modelDescription": "Executa ações de ciclo de vida (start, stop ou restart) para um serviço do Coolify.",
        "userDescription": "Executa start/stop/restart em serviço do Coolify.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "services",
          "lifecycle"
        ],
        "icon": "$(debug-restart)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": [
                "start",
                "stop",
                "restart"
              ],
              "description": "Lifecycle action to run."
            },
            "serviceId": {
              "type": "string",
              "description": "Service UUID in Coolify."
            },
            "serviceName": {
              "type": "string",
              "description": "Service name in Coolify."
            }
          },
          "required": [
            "action"
          ]
        }
      },
      {
        "name": "coolify-listDatabases",
        "toolReferenceName": "coolifyListDatabases",
        "displayName": "Coolify Listar Bancos de Dados",
        "modelDescription": "Lista bancos de dados disponíveis no Coolify com status e metadados.",
        "userDescription": "Lista bancos de dados do Coolify.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "databases"
        ],
        "icon": "$(database)",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "coolify-databaseLifecycle",
        "toolReferenceName": "coolifyDatabaseLifecycle",
        "displayName": "Coolify Ciclo de Vida do Banco de Dados",
        "modelDescription": "Executa ações de ciclo de vida (start, stop ou restart) para um banco de dados do Coolify.",
        "userDescription": "Executa start/stop/restart em banco de dados do Coolify.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "databases",
          "lifecycle"
        ],
        "icon": "$(debug-restart)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": [
                "start",
                "stop",
                "restart"
              ],
              "description": "Lifecycle action to run."
            },
            "databaseId": {
              "type": "string",
              "description": "Database UUID in Coolify."
            },
            "databaseName": {
              "type": "string",
              "description": "Database name in Coolify."
            }
          },
          "required": [
            "action"
          ]
        }
      }
    ],
    "chatParticipants": [
      {
        "id": "coolify.chat",
        "name": "coolify",
        "fullName": "Coolify Assistant",
        "description": "Gerencie recursos do Coolify pelo chat: configurar, listar, status, deploy, logs e ações de ciclo de vida."
      }
    ],
    "configuration": {
      "title": "Coolify",
      "properties": {
        "coolify.allowInsecureHttp": {
          "type": "boolean",
          "default": false,
          "description": "Allow HTTP (insecure) connections to Coolify server. HTTPS is strongly recommended."
        },
        "coolify.language": {
          "type": "string",
          "default": "en",
          "enum": [
            "en",
            "pt-BR"
          ],
          "enumDescriptions": [
            "English",
            "Português (Brasil)"
          ],
          "description": "UI language for Coolify extension views."
        },
        "coolify.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "enumDescriptions": [
            "Verbose logs for troubleshooting.",
            "General operational logs.",
            "Warnings and errors only.",
            "Errors only."
          ],
          "description": "Controls how much the Coolify output channel logs."
        },
        "coolify.envSyncConflictStrategy": {
          "type": "string",
          "default": "prompt",
          "enum": [
            "prompt",
            "file-all",
            "remote-all",
            "per-key"
          ],
          "enumDescriptions": [
            "Ask which strategy to use whenever conflicts are found.",
            "Always apply values from .env for conflicting keys.",
            "Always keep remote values for conflicting keys.",
            "Always resolve conflicts key by key."
          ],
          "description": "Default strategy to resolve environment variable conflicts during .env sync."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "coolify-sidebar",
          "title": "Coolify Deployments",
          "icon": "public/logo.svg"
        }
      ]
    },
    "views": {
      "coolify-sidebar": [
        {
          "type": "webview",
          "id": "coolify-deployments",
          "name": "Coolify",
          "visibility": "visible"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "coolify.refreshApplications",
          "when": "view == coolify-deployments && coolify.viewState == ready",
          "group": "navigation"
        },
        {
          "command": "coolify.sidebarLoadingIndicator",
          "when": "view == coolify-deployments && coolify.viewState == loading",
          "group": "navigation"
        },
        {
          "command": "coolify.sidebarErrorIndicator",
          "when": "view == coolify-deployments && coolify.viewState == error",
          "group": "navigation"
        }
      ]
    },
    "commands": [
      {
        "command": "coolify.configure",
        "title": "Coolify: Configure",
        "enablement": "!coolify.isConfigured"
      },
      {
        "command": "coolify.reconfigure",
        "title": "Coolify: Reconfigure",
        "enablement": "coolify.isConfigured",
        "icon": "$(refresh)"
      },
      {
        "command": "coolify.createContext",
        "title": "Coolify: Create Context"
      },
      {
        "command": "coolify.switchContext",
        "title": "Coolify: Switch Context"
      },
      {
        "command": "coolify.deleteContext",
        "title": "Coolify: Delete Context"
      },
      {
        "command": "coolify.refreshApplications",
        "title": "Coolify: Refresh Applications",
        "icon": "$(refresh)"
      },
      {
        "command": "coolify.sidebarLoadingIndicator",
        "title": "Coolify: Loading",
        "icon": "$(sync~spin)",
        "enablement": "coolify.isConfigured"
      },
      {
        "command": "coolify.sidebarErrorIndicator",
        "title": "Coolify: Last Refresh Failed (Click to Retry)",
        "icon": "$(warning)",
        "enablement": "coolify.isConfigured"
      },
      {
        "command": "coolify.startDeployment",
        "title": "Coolify: Start Deployment"
      },
      {
        "command": "coolify.startApplication",
        "title": "Coolify: Start Application"
      },
      {
        "command": "coolify.stopApplication",
        "title": "Coolify: Stop Application"
      },
      {
        "command": "coolify.restartApplication",
        "title": "Coolify: Restart Application"
      },
      {
        "command": "coolify.selectLanguage",
        "title": "Coolify: Select Language"
      },
      {
        "command": "coolify.setEnvSyncConflictStrategy",
        "title": "Coolify: Set Env Sync Conflict Strategy"
      },
      {
        "command": "coolify.showLogs",
        "title": "Coolify: Show Logs"
      },
      {
        "command": "coolify.listEnvironmentVariables",
        "title": "Coolify: List Environment Variables"
      },
      {
        "command": "coolify.createEnvironmentVariable",
        "title": "Coolify: Create Environment Variable"
      },
      {
        "command": "coolify.updateEnvironmentVariable",
        "title": "Coolify: Update Environment Variable"
      },
      {
        "command": "coolify.deleteEnvironmentVariable",
        "title": "Coolify: Delete Environment Variable"
      },
      {
        "command": "coolify.syncEnvironmentVariablesFromFile",
        "title": "Coolify: Sync Environment Variables from .env"
      },
      {
        "command": "coolify.listDeployments",
        "title": "Coolify: List Deployments"
      },
      {
        "command": "coolify.showDeploymentDetails",
        "title": "Coolify: Show Deployment Details"
      },
      {
        "command": "coolify.cancelDeployment",
        "title": "Coolify: Cancel Deployment"
      },
      {
        "command": "coolify.showDeploymentLogs",
        "title": "Coolify: Show Deployment Logs"
      },
      {
        "command": "coolify.listServices",
        "title": "Coolify: List Services"
      },
      {
        "command": "coolify.startService",
        "title": "Coolify: Start Service"
      },
      {
        "command": "coolify.stopService",
        "title": "Coolify: Stop Service"
      },
      {
        "command": "coolify.restartService",
        "title": "Coolify: Restart Service"
      },
      {
        "command": "coolify.listDatabases",
        "title": "Coolify: List Databases"
      },
      {
        "command": "coolify.startDatabase",
        "title": "Coolify: Start Database"
      },
      {
        "command": "coolify.stopDatabase",
        "title": "Coolify: Stop Database"
      },
      {
        "command": "coolify.restartDatabase",
        "title": "Coolify: Restart Database"
      },
      {
        "command": "coolify.listApplicationDeployments",
        "title": "Coolify: List Application Deployments"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js && node scripts/copy-templates.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production && node scripts/copy-templates.js",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test:coverage": "pnpm run compile-tests && pnpm dlx c8 --reporter=text --reporter=lcov --check-coverage --lines 35 --functions 35 --branches 20 --statements 35 pnpm dlx mocha --ui tdd \"out/test/**/*.test.js\" --exclude \"out/test/extension.test.js\"",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^9.21.0",
    "esbuild": "^0.25.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.3",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1"
  }
}
