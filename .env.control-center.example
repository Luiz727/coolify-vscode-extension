# ============================================================================
# Control Center - configuracao
#
# OBRIGATORIO: o backend se recusa a subir se qualquer item da secao 1 ou 2
# estiver faltando. Isso e proposital: o painel opera todo o seu Coolify, e
# subir sem autenticacao publicaria esse poder para quem alcancasse a porta.
# ============================================================================

# --- 1. Conexao com o Coolify (obrigatorio) ---------------------------------
COOLIFY_BASE_URL=https://coolify.seudominio.com
COOLIFY_TOKEN=seu_token_aqui

# --- 2. Acesso ao painel (obrigatorio) --------------------------------------
WEB_AUTH_USER=admin

# Gere o hash com:  cd web-control-center/backend && npm run hash-password -- "sua-senha-forte"
# Nunca use senha em texto puro em producao.
WEB_AUTH_PASSWORD_HASH=

# --- 3. Opcionais -----------------------------------------------------------

# Token fixo para automacoes (minimo 32 caracteres). Deixe vazio se nao usar.
WEB_ACCESS_TOKEN=

# Duracao da sessao de login, em milissegundos (padrao: 8h).
SESSION_TTL_MS=28800000

# Caminho do arquivo JSONL de auditoria (rotaciona sozinho por tamanho).
AUDIT_LOG_PATH=/var/lib/control-center/audit.log.jsonl

# --- 4. Historico e metricas (opcional) -------------------------------------
# Postgres provisionado no proprio Coolify. Sem esta variavel o painel funciona
# normalmente, apenas sem uptime, MTTR e taxa de sucesso de deploy.
HISTORY_DATABASE_URL=

# --- 5. Monitoramento da VPS via Hostinger (opcional) -----------------------
# Sem o token, a secao de infraestrutura simplesmente nao aparece.
# ATENCAO: este token da poder sobre a conta Hostinger inteira. Ele fica apenas
# no backend e nunca e enviado ao navegador.
HOSTINGER_API_TOKEN=

# Limiares de alerta, em porcentagem.
ALERT_CPU_PCT=85
ALERT_RAM_PCT=90
ALERT_DISK_PCT=85
