{
  "name": "vscode-coolify",
  "displayName": "Coolify Deployments",
  "description": "Track and deploy your Coolify applications right from Visual Studio Code",
  "version": "1.1.0",
  "author": {
    "name": "Nixcon Sistemas"
  },
  "publisher": "NixconSistemas",
  "icon": "public/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Luiz727/coolify-vscode-extension"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onChatParticipant:coolify.chat",
    "onLanguageModelTool:coolify-configure",
    "onLanguageModelTool:coolify-healthCheck",
    "onLanguageModelTool:coolify-listApplications",
    "onLanguageModelTool:coolify-getApplicationStatus",
    "onLanguageModelTool:coolify-getApplicationLogs",
    "onLanguageModelTool:coolify-listApplicationEnvs",
    "onLanguageModelTool:coolify-setApplicationEnv",
    "onLanguageModelTool:coolify-startDeployment",
    "onLanguageModelTool:coolify-applicationLifecycle",
    "onLanguageModelTool:coolify-listDeployments",
    "onLanguageModelTool:coolify-getDeploymentLogs",
    "onLanguageModelTool:coolify-cancelDeployment",
    "onLanguageModelTool:coolify-listServices",
    "onLanguageModelTool:coolify-serviceLifecycle",
    "onLanguageModelTool:coolify-listDatabases",
    "onLanguageModelTool:coolify-databaseLifecycle",
    "onLanguageModelTool:coolify-listDatabaseBackups",
    "onLanguageModelTool:coolify-runDatabaseBackup",
    "onLanguageModelTool:coolify-listProjects",
    "onLanguageModelTool:coolify-listServers",
    "onLanguageModelTool:coolify-getServerResources",
    "onView:coolify-deployments",
    "onCommand:coolify.configure",
    "onCommand:coolify.reconfigure",
    "onCommand:coolify.createContext",
    "onCommand:coolify.switchContext",
    "onCommand:coolify.deleteContext",
    "onCommand:coolify.refreshApplications",
    "onCommand:coolify.sidebarLoadingIndicator",
    "onCommand:coolify.sidebarErrorIndicator",
    "onCommand:coolify.startDeployment",
    "onCommand:coolify.startApplication",
    "onCommand:coolify.stopApplication",
    "onCommand:coolify.restartApplication",
    "onCommand:coolify.selectLanguage",
    "onCommand:coolify.setEnvSyncConflictStrategy",
    "onCommand:coolify.showLogs",
    "onCommand:coolify.listEnvironmentVariables",
    "onCommand:coolify.createEnvironmentVariable",
    "onCommand:coolify.updateEnvironmentVariable",
    "onCommand:coolify.deleteEnvironmentVariable",
    "onCommand:coolify.syncEnvironmentVariablesFromFile",
    "onCommand:coolify.listDeployments",
    "onCommand:coolify.showDeploymentDetails",
    "onCommand:coolify.cancelDeployment",
    "onCommand:coolify.showDeploymentLogs",
    "onCommand:coolify.listServices",
    "onCommand:coolify.startService",
    "onCommand:coolify.stopService",
    "onCommand:coolify.restartService",
    "onCommand:coolify.listDatabases",
    "onCommand:coolify.startDatabase",
    "onCommand:coolify.stopDatabase",
    "onCommand:coolify.restartDatabase",
    "onCommand:coolify.listApplicationDeployments"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languageModelTools": [
      {
        "name": "coolify-configure",
        "toolReferenceName": "coolifyConfigure",
        "displayName": "Coolify Configurar",
        "modelDescription": "Inicia o fluxo de configuracao do Coolify para definir URL do servidor e token da API com seguranca.",
        "userDescription": "Configura URL e token da API do Coolify.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "configuration"
        ],
        "icon": "$(gear)",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "coolify-healthCheck",
        "toolReferenceName": "coolifyHealthCheck",
        "displayName": "Coolify Verificar Saude",
        "modelDescription": "Verifica conectividade com o Coolify e validade do token da API.",
        "userDescription": "Valida conectividade e token do Coolify.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "health"
        ],
        "icon": "$(pulse)",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "coolify-listApplications",
        "toolReferenceName": "coolifyListApplications",
        "displayName": "Coolify Listar Aplicacoes",
        "modelDescription": "Lista todas as aplicacoes do Coolify com status, saude do healthcheck, branch e dominio.",
        "userDescription": "Lista aplicacoes do Coolify.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "applications"
        ],
        "icon": "$(list-unordered)",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "coolify-getApplicationStatus",
        "toolReferenceName": "coolifyGetApplicationStatus",
        "displayName": "Coolify Status da Aplicacao",
        "modelDescription": "Consulta status detalhado de uma aplicacao, incluindo se o healthcheck esta falhando.",
        "userDescription": "Consulta status de uma aplicacao.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "applications"
        ],
        "icon": "$(info)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "appId": {
              "type": "string",
              "description": "UUID da aplicacao no Coolify."
            },
            "appName": {
              "type": "string",
              "description": "Nome da aplicacao no Coolify."
            }
          }
        }
      },
      {
        "name": "coolify-getApplicationLogs",
        "toolReferenceName": "coolifyGetApplicationLogs",
        "displayName": "Coolify Logs do Container",
        "modelDescription": "Obtem os logs em execucao (runtime) do container de uma aplicacao. Use para diagnosticar uma aplicacao que ja esta no ar; para logs de build use coolify-getDeploymentLogs.",
        "userDescription": "Logs do container em execucao.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "logs"
        ],
        "icon": "$(output)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "appId": {
              "type": "string",
              "description": "UUID da aplicacao no Coolify."
            },
            "appName": {
              "type": "string",
              "description": "Nome da aplicacao no Coolify."
            }
          }
        }
      },
      {
        "name": "coolify-listApplicationEnvs",
        "toolReferenceName": "coolifyListApplicationEnvs",
        "displayName": "Coolify Listar Variaveis",
        "modelDescription": "Lista as chaves das variaveis de ambiente de uma aplicacao. Os valores nunca sao retornados.",
        "userDescription": "Lista chaves de variaveis de ambiente.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "environment"
        ],
        "icon": "$(symbol-key)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "appId": {
              "type": "string",
              "description": "UUID da aplicacao no Coolify."
            },
            "appName": {
              "type": "string",
              "description": "Nome da aplicacao no Coolify."
            }
          }
        }
      },
      {
        "name": "coolify-setApplicationEnv",
        "toolReferenceName": "coolifySetApplicationEnv",
        "displayName": "Coolify Definir Variavel",
        "modelDescription": "Cria ou atualiza uma variavel de ambiente de uma aplicacao. Requer confirmacao do usuario e identificacao explicita da aplicacao.",
        "userDescription": "Define variavel de ambiente.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "environment"
        ],
        "icon": "$(symbol-key)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "appId": {
              "type": "string",
              "description": "UUID da aplicacao no Coolify."
            },
            "appName": {
              "type": "string",
              "description": "Nome da aplicacao no Coolify."
            },
            "key": {
              "type": "string",
              "description": "Nome da variavel."
            },
            "value": {
              "type": "string",
              "description": "Valor da variavel."
            },
            "isPreview": {
              "type": "boolean",
              "description": "Se a variavel vale para deploys de preview."
            }
          },
          "required": [
            "key",
            "value"
          ],
          "anyOf": [
            {
              "required": [
                "appId"
              ]
            },
            {
              "required": [
                "appName"
              ]
            }
          ]
        }
      },
      {
        "name": "coolify-startDeployment",
        "toolReferenceName": "coolifyStartDeployment",
        "displayName": "Coolify Iniciar Deployment",
        "modelDescription": "Inicia um novo deployment de uma aplicacao. ACAO DESTRUTIVA: requer confirmacao do usuario e identificacao explicita da aplicacao (appId ou appName). Nunca assume um alvo padrao.",
        "userDescription": "Inicia deployment de uma aplicacao.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "deployments"
        ],
        "icon": "$(rocket)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "appId": {
              "type": "string",
              "description": "UUID da aplicacao no Coolify."
            },
            "appName": {
              "type": "string",
              "description": "Nome da aplicacao no Coolify."
            },
            "force": {
              "type": "boolean",
              "description": "Forca rebuild ignorando cache."
            }
          },
          "anyOf": [
            {
              "required": [
                "appId"
              ]
            },
            {
              "required": [
                "appName"
              ]
            }
          ]
        }
      },
      {
        "name": "coolify-applicationLifecycle",
        "toolReferenceName": "coolifyApplicationLifecycle",
        "displayName": "Coolify Ciclo de Vida da Aplicacao",
        "modelDescription": "Executa start, stop ou restart em uma aplicacao. ACAO DESTRUTIVA: requer confirmacao do usuario e identificacao explicita da aplicacao.",
        "userDescription": "Start/stop/restart de aplicacao.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "applications"
        ],
        "icon": "$(debug-restart)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": [
                "start",
                "stop",
                "restart"
              ],
              "description": "Acao de ciclo de vida."
            },
            "appId": {
              "type": "string",
              "description": "UUID da aplicacao no Coolify."
            },
            "appName": {
              "type": "string",
              "description": "Nome da aplicacao no Coolify."
            }
          },
          "required": [
            "action"
          ],
          "anyOf": [
            {
              "required": [
                "appId"
              ]
            },
            {
              "required": [
                "appName"
              ]
            }
          ]
        }
      },
      {
        "name": "coolify-listDeployments",
        "toolReferenceName": "coolifyListDeployments",
        "displayName": "Coolify Listar Deployments",
        "modelDescription": "Lista o historico de deployments. Sem filtro retorna os mais recentes de todas as aplicacoes; com appId ou appName retorna o historico daquela aplicacao. Esta ferramenta apenas le dados e nunca dispara um deploy.",
        "userDescription": "Lista historico de deployments.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "deployments"
        ],
        "icon": "$(history)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "appId": {
              "type": "string",
              "description": "UUID da aplicacao no Coolify."
            },
            "appName": {
              "type": "string",
              "description": "Nome da aplicacao no Coolify."
            },
            "take": {
              "type": "number",
              "description": "Quantidade de registros (1-50)."
            }
          }
        }
      },
      {
        "name": "coolify-getDeploymentLogs",
        "toolReferenceName": "coolifyGetDeploymentLogs",
        "displayName": "Coolify Logs de Deployment",
        "modelDescription": "Obtem os logs de build e deploy. Sem deploymentId usa o deployment mais recente da aplicacao informada.",
        "userDescription": "Logs de um deployment.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "logs"
        ],
        "icon": "$(output)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "deploymentId": {
              "type": "string",
              "description": "UUID do deployment no Coolify."
            },
            "appId": {
              "type": "string",
              "description": "UUID da aplicacao no Coolify."
            },
            "appName": {
              "type": "string",
              "description": "Nome da aplicacao no Coolify."
            }
          }
        }
      },
      {
        "name": "coolify-cancelDeployment",
        "toolReferenceName": "coolifyCancelDeployment",
        "displayName": "Coolify Cancelar Deployment",
        "modelDescription": "Cancela um deployment em andamento. ACAO DESTRUTIVA: requer confirmacao do usuario.",
        "userDescription": "Cancela um deployment.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "deployments"
        ],
        "icon": "$(stop-circle)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "deploymentId": {
              "type": "string",
              "description": "UUID do deployment no Coolify."
            }
          },
          "required": [
            "deploymentId"
          ]
        }
      },
      {
        "name": "coolify-listServices",
        "toolReferenceName": "coolifyListServices",
        "displayName": "Coolify Listar Servicos",
        "modelDescription": "Lista todos os servicos do Coolify com status e saude.",
        "userDescription": "Lista servicos do Coolify.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "services"
        ],
        "icon": "$(server-process)",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "coolify-serviceLifecycle",
        "toolReferenceName": "coolifyServiceLifecycle",
        "displayName": "Coolify Ciclo de Vida do Servico",
        "modelDescription": "Executa start, stop ou restart em um servico. ACAO DESTRUTIVA: requer confirmacao do usuario e identificacao explicita do servico.",
        "userDescription": "Start/stop/restart de servico.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "services"
        ],
        "icon": "$(debug-restart)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": [
                "start",
                "stop",
                "restart"
              ],
              "description": "Acao de ciclo de vida."
            },
            "serviceId": {
              "type": "string",
              "description": "UUID do servico no Coolify."
            },
            "serviceName": {
              "type": "string",
              "description": "Nome do servico no Coolify."
            }
          },
          "required": [
            "action"
          ],
          "anyOf": [
            {
              "required": [
                "serviceId"
              ]
            },
            {
              "required": [
                "serviceName"
              ]
            }
          ]
        }
      },
      {
        "name": "coolify-listDatabases",
        "toolReferenceName": "coolifyListDatabases",
        "displayName": "Coolify Listar Bancos",
        "modelDescription": "Lista todos os bancos de dados do Coolify com status e saude.",
        "userDescription": "Lista bancos de dados.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "databases"
        ],
        "icon": "$(database)",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "coolify-databaseLifecycle",
        "toolReferenceName": "coolifyDatabaseLifecycle",
        "displayName": "Coolify Ciclo de Vida do Banco",
        "modelDescription": "Executa start, stop ou restart em um banco de dados. ACAO DESTRUTIVA: parar um banco derruba todas as aplicacoes que dependem dele. Requer confirmacao do usuario e identificacao explicita.",
        "userDescription": "Start/stop/restart de banco.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "databases"
        ],
        "icon": "$(debug-restart)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": [
                "start",
                "stop",
                "restart"
              ],
              "description": "Acao de ciclo de vida."
            },
            "databaseId": {
              "type": "string",
              "description": "UUID do banco no Coolify."
            },
            "databaseName": {
              "type": "string",
              "description": "Nome do banco no Coolify."
            }
          },
          "required": [
            "action"
          ],
          "anyOf": [
            {
              "required": [
                "databaseId"
              ]
            },
            {
              "required": [
                "databaseName"
              ]
            }
          ]
        }
      },
      {
        "name": "coolify-listDatabaseBackups",
        "toolReferenceName": "coolifyListDatabaseBackups",
        "displayName": "Coolify Backups do Banco",
        "modelDescription": "Lista os agendamentos de backup de um banco e as execucoes recentes de cada um. Observacao: a API do Coolify nao expoe restauracao de backup, apenas agendamento e execucao.",
        "userDescription": "Lista agendamentos e execucoes de backup.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "databases",
          "backups"
        ],
        "icon": "$(archive)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "databaseId": {
              "type": "string",
              "description": "UUID do banco no Coolify."
            },
            "databaseName": {
              "type": "string",
              "description": "Nome do banco no Coolify."
            }
          }
        }
      },
      {
        "name": "coolify-runDatabaseBackup",
        "toolReferenceName": "coolifyRunDatabaseBackup",
        "displayName": "Coolify Executar Backup",
        "modelDescription": "Dispara imediatamente um backup a partir de um agendamento existente. Requer confirmacao do usuario.",
        "userDescription": "Executa backup imediato.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "databases",
          "backups"
        ],
        "icon": "$(save)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "databaseId": {
              "type": "string",
              "description": "UUID do banco no Coolify."
            },
            "databaseName": {
              "type": "string",
              "description": "Nome do banco no Coolify."
            },
            "scheduleId": {
              "type": "string",
              "description": "UUID do agendamento de backup."
            }
          },
          "anyOf": [
            {
              "required": [
                "databaseId"
              ]
            },
            {
              "required": [
                "databaseName"
              ]
            }
          ]
        }
      },
      {
        "name": "coolify-listProjects",
        "toolReferenceName": "coolifyListProjects",
        "displayName": "Coolify Listar Projetos",
        "modelDescription": "Lista os projetos do Coolify.",
        "userDescription": "Lista projetos.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "projects"
        ],
        "icon": "$(folder)",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "coolify-listServers",
        "toolReferenceName": "coolifyListServers",
        "displayName": "Coolify Listar Servidores",
        "modelDescription": "Lista os servidores (VPS) registrados no Coolify com sinais de causa raiz: acessivel, contagem de falhas de conexao, alerta de disco cheio, tipo de proxy e quantidade de recursos hospedados. Use para descobrir por que varios recursos cairam ao mesmo tempo.",
        "userDescription": "Lista servidores e saude da infraestrutura.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "servers",
          "infrastructure"
        ],
        "icon": "$(server)",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "coolify-getServerResources",
        "toolReferenceName": "coolifyGetServerResources",
        "displayName": "Coolify Recursos do Servidor",
        "modelDescription": "Lista quais aplicacoes, servicos e bancos rodam em um servidor especifico, com o status de cada um.",
        "userDescription": "Recursos hospedados em um servidor.",
        "canBeReferencedInPrompt": true,
        "tags": [
          "coolify",
          "servers",
          "infrastructure"
        ],
        "icon": "$(server)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "serverId": {
              "type": "string",
              "description": "UUID do servidor no Coolify."
            },
            "serverName": {
              "type": "string",
              "description": "Nome do servidor no Coolify."
            }
          }
        }
      }
    ],
    "chatParticipants": [
      {
        "id": "coolify.chat",
        "name": "coolify",
        "fullName": "Coolify Assistant",
        "description": "Gerencie recursos do Coolify pelo chat: configurar, listar, status, deploy, logs e ações de ciclo de vida."
      }
    ],
    "configuration": {
      "title": "Coolify",
      "properties": {
        "coolify.allowInsecureHttp": {
          "type": "boolean",
          "default": false,
          "description": "Allow HTTP (insecure) connections to Coolify server. HTTPS is strongly recommended."
        },
        "coolify.language": {
          "type": "string",
          "default": "en",
          "enum": [
            "en",
            "pt-BR"
          ],
          "enumDescriptions": [
            "English",
            "Português (Brasil)"
          ],
          "description": "UI language for Coolify extension views."
        },
        "coolify.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "enumDescriptions": [
            "Verbose logs for troubleshooting.",
            "General operational logs.",
            "Warnings and errors only.",
            "Errors only."
          ],
          "description": "Controls how much the Coolify output channel logs."
        },
        "coolify.envSyncConflictStrategy": {
          "type": "string",
          "default": "prompt",
          "enum": [
            "prompt",
            "file-all",
            "remote-all",
            "per-key"
          ],
          "enumDescriptions": [
            "Ask which strategy to use whenever conflicts are found.",
            "Always apply values from .env for conflicting keys.",
            "Always keep remote values for conflicting keys.",
            "Always resolve conflicts key by key."
          ],
          "description": "Default strategy to resolve environment variable conflicts during .env sync."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "coolify-sidebar",
          "title": "Coolify Deployments",
          "icon": "public/logo.svg"
        }
      ]
    },
    "views": {
      "coolify-sidebar": [
        {
          "type": "webview",
          "id": "coolify-deployments",
          "name": "Coolify",
          "visibility": "visible"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "coolify.refreshApplications",
          "when": "view == coolify-deployments && coolify.viewState == ready",
          "group": "navigation"
        },
        {
          "command": "coolify.sidebarLoadingIndicator",
          "when": "view == coolify-deployments && coolify.viewState == loading",
          "group": "navigation"
        },
        {
          "command": "coolify.sidebarErrorIndicator",
          "when": "view == coolify-deployments && coolify.viewState == error",
          "group": "navigation"
        }
      ]
    },
    "commands": [
      {
        "command": "coolify.configure",
        "title": "Coolify: Configure",
        "enablement": "!coolify.isConfigured"
      },
      {
        "command": "coolify.reconfigure",
        "title": "Coolify: Reconfigure",
        "enablement": "coolify.isConfigured",
        "icon": "$(refresh)"
      },
      {
