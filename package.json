{
  "name": "vscode-coolify",
  "displayName": "Coolify Deployments",
  "description": "Track and deploy your Coolify applications right from Visual Studio Code",
  "version": "1.0.4",
  "author": {
    "name": "Nixcon Sistemas"
  },
  "publisher": "NixconSistemas",
  "icon": "public/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Luiz727/coolify-vscode-extension"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:coolify-deployments",
    "onCommand:coolify.configure",
    "onCommand:coolify.reconfigure",
    "onCommand:coolify.createContext",
    "onCommand:coolify.switchContext",
    "onCommand:coolify.deleteContext",
    "onCommand:coolify.refreshApplications",
    "onCommand:coolify.startDeployment",
    "onCommand:coolify.startApplication",
    "onCommand:coolify.stopApplication",
    "onCommand:coolify.restartApplication",
    "onCommand:coolify.selectLanguage",
    "onCommand:coolify.setEnvSyncConflictStrategy",
    "onCommand:coolify.showLogs",
    "onCommand:coolify.listEnvironmentVariables",
    "onCommand:coolify.createEnvironmentVariable",
    "onCommand:coolify.updateEnvironmentVariable",
    "onCommand:coolify.deleteEnvironmentVariable",
    "onCommand:coolify.syncEnvironmentVariablesFromFile",
    "onCommand:coolify.listDeployments",
    "onCommand:coolify.showDeploymentDetails",
    "onCommand:coolify.cancelDeployment",
    "onCommand:coolify.showDeploymentLogs"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Coolify",
      "properties": {
        "coolify.allowInsecureHttp": {
          "type": "boolean",
          "default": false,
          "description": "Allow HTTP (insecure) connections to Coolify server. HTTPS is strongly recommended."
        },
        "coolify.language": {
          "type": "string",
          "default": "en",
          "enum": [
            "en",
            "pt-BR"
          ],
          "enumDescriptions": [
            "English",
            "Português (Brasil)"
          ],
          "description": "UI language for Coolify extension views."
        },
        "coolify.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "enumDescriptions": [
            "Verbose logs for troubleshooting.",
            "General operational logs.",
            "Warnings and errors only.",
            "Errors only."
          ],
          "description": "Controls how much the Coolify output channel logs."
        },
        "coolify.envSyncConflictStrategy": {
          "type": "string",
          "default": "prompt",
          "enum": [
            "prompt",
            "file-all",
            "remote-all",
            "per-key"
          ],
          "enumDescriptions": [
            "Ask which strategy to use whenever conflicts are found.",
            "Always apply values from .env for conflicting keys.",
            "Always keep remote values for conflicting keys.",
            "Always resolve conflicts key by key."
          ],
          "description": "Default strategy to resolve environment variable conflicts during .env sync."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "coolify-sidebar",
          "title": "Coolify Deployments",
          "icon": "public/logo.svg"
        }
      ]
    },
    "views": {
      "coolify-sidebar": [
        {
          "type": "webview",
          "id": "coolify-deployments",
          "name": "Coolify",
          "visibility": "visible"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "coolify.reconfigure",
          "when": "view == coolify-deployments && coolify.isConfigured",
          "group": "navigation"
        }
      ]
    },
    "commands": [
      {
        "command": "coolify.configure",
        "title": "Coolify: Configure",
        "enablement": "!coolify.isConfigured"
      },
      {
        "command": "coolify.reconfigure",
        "title": "Coolify: Reconfigure",
        "enablement": "coolify.isConfigured",
        "icon": "$(refresh)"
      },
      {
        "command": "coolify.createContext",
        "title": "Coolify: Create Context"
      },
      {
        "command": "coolify.switchContext",
        "title": "Coolify: Switch Context"
      },
      {
        "command": "coolify.deleteContext",
        "title": "Coolify: Delete Context"
      },
      {
        "command": "coolify.refreshApplications",
        "title": "Coolify: Refresh Applications",
        "icon": "$(refresh)"
      },
      {
        "command": "coolify.startDeployment",
        "title": "Coolify: Start Deployment"
      },
      {
        "command": "coolify.startApplication",
        "title": "Coolify: Start Application"
      },
      {
        "command": "coolify.stopApplication",
        "title": "Coolify: Stop Application"
      },
      {
        "command": "coolify.restartApplication",
        "title": "Coolify: Restart Application"
      },
      {
        "command": "coolify.selectLanguage",
        "title": "Coolify: Select Language"
      },
      {
        "command": "coolify.setEnvSyncConflictStrategy",
        "title": "Coolify: Set Env Sync Conflict Strategy"
      },
      {
        "command": "coolify.showLogs",
        "title": "Coolify: Show Logs"
      },
      {
        "command": "coolify.listEnvironmentVariables",
        "title": "Coolify: List Environment Variables"
      },
      {
        "command": "coolify.createEnvironmentVariable",
        "title": "Coolify: Create Environment Variable"
      },
      {
        "command": "coolify.updateEnvironmentVariable",
        "title": "Coolify: Update Environment Variable"
      },
      {
        "command": "coolify.deleteEnvironmentVariable",
        "title": "Coolify: Delete Environment Variable"
      },
      {
        "command": "coolify.syncEnvironmentVariablesFromFile",
        "title": "Coolify: Sync Environment Variables from .env"
      },
      {
        "command": "coolify.listDeployments",
        "title": "Coolify: List Deployments"
      },
      {
        "command": "coolify.showDeploymentDetails",
        "title": "Coolify: Show Deployment Details"
      },
      {
        "command": "coolify.cancelDeployment",
        "title": "Coolify: Cancel Deployment"
      },
      {
        "command": "coolify.showDeploymentLogs",
        "title": "Coolify: Show Deployment Logs"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js && node scripts/copy-templates.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production && node scripts/copy-templates.js",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test:coverage": "pnpm run compile-tests && pnpm dlx c8 --reporter=text --reporter=lcov --check-coverage --lines 35 --functions 35 --branches 20 --statements 35 pnpm dlx mocha --ui tdd \"out/test/**/*.test.js\" --exclude \"out/test/extension.test.js\"",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^9.21.0",
    "esbuild": "^0.25.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.3",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1"
  }
}
